# Copy this file to `.env` in the project root (`.env` is gitignored).
# Optional: loaded at startup via flutter_dotenv when the file exists.
#
# Never commit real API keys or production Firebase secrets to a public repo.

# --- Optional: live AI (see lib/services/ai/ai_api_service.dart) ---
# Use: openai | gemini | (leave empty for local-only assistant)
AI_PROVIDER=openai
# Required when AI_PROVIDER is openai or gemini (also overridable with --dart-define)
AI_API_KEY=your_api_key_here
# Examples: gpt-4o-mini, gemini-1.5-flash (depends on provider)
AI_MODEL=gpt-4o-mini
