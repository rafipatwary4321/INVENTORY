# INVENTORY environment template
# 1) Copy this file to `.env`
# 2) Fill values for your local/dev environment
# 3) Do NOT commit `.env` to Git

# Optional AI provider configuration
# Allowed values: openai | gemini | (leave empty for local fallback mode)
AI_PROVIDER=

# API key for selected provider
AI_API_KEY=your_api_key_here

# Model identifier for selected provider
# Example: gpt-4o-mini, gemini-1.5-flash
AI_MODEL=gpt-4o-mini
