rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Draft multitenant RBAC rules for production hardening.
    // IMPORTANT: Validate and test extensively before deploying.
    match /businesses/{businessId} {
      function signedIn() {
        return request.auth != null;
      }

      function membershipDoc() {
        return get(/databases/$(database)/documents/businesses/$(businessId)/users/$(request.auth.uid));
      }

      function isActiveMember() {
        return signedIn() && membershipDoc().exists() && membershipDoc().data.isActive == true;
      }

      function role() {
        return membershipDoc().data.role;
      }

      function isOwner() {
        return isActiveMember() && role() == 'owner';
      }

      function isAdminOrOwner() {
        return isActiveMember() && (role() == 'owner' || role() == 'admin');
      }

      function isStaffOrAbove() {
        return isActiveMember() && (role() == 'owner' || role() == 'admin' || role() == 'staff');
      }

      allow read: if isActiveMember();
      allow create, update: if isOwner();
      allow delete: if false;

      match /users/{userId} {
        allow read: if isAdminOrOwner();
        allow create, update: if isOwner();
        allow delete: if false;
      }

      match /products/{productId} {
        allow read: if isStaffOrAbove();
        allow create, update: if isAdminOrOwner();
        allow delete: if isAdminOrOwner();
      }

      match /sales/{saleId} {
        allow read: if isStaffOrAbove();
        allow create: if isStaffOrAbove();
        allow update, delete: if false;
      }

      match /sale_items/{itemId} {
        allow read: if isStaffOrAbove();
        allow create: if isStaffOrAbove();
        allow update, delete: if false;
      }

      match /stock_transactions/{txId} {
        allow read: if isStaffOrAbove();
        allow create: if isStaffOrAbove();
        allow update, delete: if false;
      }

      match /settings/{docId} {
        allow read: if isStaffOrAbove();
        allow create, update: if isOwner();
        allow delete: if false;
      }
    }
  }
}
